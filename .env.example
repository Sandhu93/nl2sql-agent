# ============================================================
# NL2SQL Agent — environment variables
# ============================================================
# Copy this file to .env and fill in your values.
# NEVER commit the real .env file to source control.
# ============================================================

# ---- OpenAI (required) -------------------------------------
# Primary LLM — GPT-4o for SQL generation, GPT-4o-mini for lighter tasks.
OPENAI_API_KEY=sk-...

# ---- Model routing (Phase 12) ------------------------------
# OPENAI_MODEL=gpt-4o          # SQL generation + SQL fixing (accuracy-critical)
# OPENAI_FAST_MODEL=gpt-4o-mini  # query rewrite, table selection, rephrase, insights

# ---- Fallback LLM providers (all optional) -----------------
# Set any of these to automatically add that provider to the fallback chain.
# The backend tries them in order when the primary LLM raises an API error.
# You also need the matching package installed — see requirements.txt.

# Anthropic Claude (pip install langchain-anthropic)
# ANTHROPIC_API_KEY=sk-ant-...

# Google Gemini (pip install langchain-google-genai)
# GOOGLE_API_KEY=AIza...

# DeepSeek — reuses langchain-openai, no extra package needed
# DEEPSEEK_API_KEY=sk-...

# Ollama — local LLMs, no API key, just a running Ollama instance
# (pip install langchain-ollama, then: ollama pull llama3.1)
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=llama3.1

# ---- PostgreSQL database -----------------------------------
DB_USER=postgres
DB_PASSWORD=1234
DB_HOST=host.docker.internal   # Use "host.docker.internal" to reach a DB on the host machine
DB_PORT=5432
DB_NAME=ipl_db                # Create this database first: createdb -U postgres nl2sql

# ---- CORS --------------------------------------------------
# Comma-separated list of allowed origins for the backend.
# Must include every frontend origin that calls this backend.
# Local dev:      ALLOWED_ORIGINS=["http://localhost:8085"]
# Production:     add your frontend domain, e.g. "https://sandeepbkadam.com"
ALLOWED_ORIGINS=["http://localhost:8085"]

# ---- MCP Chart Server (Phase 9.5) --------------------------
# Internal Docker service name — no change needed for docker compose.
# Override only if you run the MCP chart server outside Docker:
#   MCP_CHART_SERVER_URL=http://localhost:8087
# MCP_CHART_SERVER_URL=http://mcp_chart_server:8087

# ---- Rate limiting (Phase 10) ----------------------------
# Per-IP request cap on /api/query. Lower for public exposure, raise for
# trusted internal testing. Enforced via Redis (cross-replica consistent).
# RATE_LIMIT_PER_MINUTE=20

# ---- LLM concurrency (Phase 11) --------------------------
# Max simultaneous in-flight LLM API calls across all requests.
# At ~1,000 tokens/call and a 30,000 TPM limit, 5 is safe.
# Lower for free-tier keys; raise for dedicated high-TPM keys.
# LLM_MAX_CONCURRENCY=5

# ---- Response cache (Phase 11) ---------------------------
# TTL for cached first-turn question responses. Only first-turn questions
# are cached — follow-up answers depend on thread history and are never cached.
# CACHE_TTL_SECONDS=3600

# ---- Circuit breaker (Phase 11) --------------------------
# Opens the circuit (HTTP 503) after this many consecutive LLM failures
# (primary + all fallbacks exhausted). Closes after the cooldown period.
# LLM_CIRCUIT_FAILURE_THRESHOLD=5
# LLM_CIRCUIT_COOLDOWN_SECONDS=60

# ---- Redis (Phase 10) -------------------------------------
# Persistent conversation history. Internal Docker service name — no change
# needed for docker compose. Override for local dev (no Docker):
#   REDIS_URL=redis://localhost:6379/0
# REDIS_URL=redis://redis:6379/0
# Session TTL in seconds (default: 86400 = 24 hours)
# REDIS_TTL_SECONDS=86400

# ---- Frontend ----------------------------------------------
# Backend URL exposed to the Next.js client (browser-side).
# Local dev:  http://localhost:8086
# Production: https://your-backend-domain.com
NEXT_PUBLIC_BACKEND_URL=http://localhost:8086
