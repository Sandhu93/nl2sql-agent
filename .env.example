# ============================================================
# NL2SQL Agent — environment variables
# ============================================================
# Copy this file to .env and fill in your values.
# NEVER commit the real .env file to source control.
# ============================================================

# ---- OpenAI (required) -------------------------------------
# Primary LLM — GPT-4o is used for all SQL generation by default.
OPENAI_API_KEY=sk-...

# ---- Fallback LLM providers (all optional) -----------------
# Set any of these to automatically add that provider to the fallback chain.
# The backend tries them in order when the primary LLM raises an API error.
# You also need the matching package installed — see requirements.txt.

# Anthropic Claude (pip install langchain-anthropic)
# ANTHROPIC_API_KEY=sk-ant-...

# Google Gemini (pip install langchain-google-genai)
# GOOGLE_API_KEY=AIza...

# DeepSeek — reuses langchain-openai, no extra package needed
# DEEPSEEK_API_KEY=sk-...

# Ollama — local LLMs, no API key, just a running Ollama instance
# (pip install langchain-ollama, then: ollama pull llama3.1)
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=llama3.1

# ---- PostgreSQL database -----------------------------------
DB_USER=postgres
DB_PASSWORD=1234
DB_HOST=host.docker.internal   # Use "host.docker.internal" to reach a DB on the host machine
DB_PORT=5432
DB_NAME=ipl_db                # Create this database first: createdb -U postgres nl2sql

# ---- CORS --------------------------------------------------
# Comma-separated list of allowed origins for the backend.
# Must include every frontend origin that calls this backend.
# Local dev:      ALLOWED_ORIGINS=["http://localhost:8085"]
# Production:     add your frontend domain, e.g. "https://sandeepbkadam.com"
ALLOWED_ORIGINS=["http://localhost:8085","https://backend.sandeepbkadam.com"]

# ---- Frontend ----------------------------------------------
# Backend URL exposed to the Next.js client (browser-side).
# Local dev:  http://localhost:8086
# Production: https://backend.sandeepbkadam.com
NEXT_PUBLIC_BACKEND_URL=https://backend.sandeepbkadam.com
